# Copy to .env for local development:  cp .env.example .env
# Never commit .env — it is gitignored. These are DEV defaults only;
# operators must override all secrets in production.

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Meeting defaults (operator-tunable) ---
# Server-enforced participant cap per room (FR-5).
MAX_PARTICIPANTS=100
# Default state of the "admit guests manually" (waiting room) toggle for new meetings.
WAITING_ROOM_DEFAULT=false
# Invite links expire this many hours after creation (0 = never).
LINK_EXPIRY_HOURS=0

# --- Admin ---
# Gate for the read-only /admin status page (?key=…). Leave empty to disable the page.
ADMIN_KEY=

# --- Postgres ---
# These three are read by docker-compose to provision the DB container.
POSTGRES_USER=hearth
POSTGRES_PASSWORD=hearth_dev_password
POSTGRES_DB=hearth
# The app + migration runner connect via DATABASE_URL.
DATABASE_URL=postgres://hearth:hearth_dev_password@localhost:5432/hearth

# --- LiveKit (media engine) ---
# Server-side URL used to mint tokens / call the LiveKit API.
LIVEKIT_URL=ws://localhost:7880
# Public URL the browser connects to (must be reachable by clients).
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
# Must match the keys block in livekit/livekit.yaml.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_at_least_32_characters

# --- TURN (coturn, for NAT traversal) ---
TURN_USER=hearth
TURN_PASSWORD=hearth_dev_password
