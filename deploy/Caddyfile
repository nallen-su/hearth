# Caddy terminates TLS and reverse-proxies the app and LiveKit signaling.
# Caddy fetches/renews Let's Encrypt certs automatically. Replace the domains.
#
# NOTE: this covers HTTPS + the LiveKit *signaling* WebSocket only. LiveKit *media*
# (WebRTC/UDP) does NOT flow through Caddy — it goes directly to the host's public IP and
# is handled by LiveKit + coturn (see DEPLOY.md and livekit/livekit.yaml for prod).

meet.example.com {
	reverse_proxy app:3000
}

# LiveKit signaling (WebSocket). Caddy proxies WS transparently.
# Point NEXT_PUBLIC_LIVEKIT_URL at wss://livekit.example.com.
livekit.example.com {
	reverse_proxy livekit:7880
}
